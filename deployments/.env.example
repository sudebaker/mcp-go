# MCP Orchestrator Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# LLM Configuration
# =============================================================================

# URL of the LLM API (Ollama, vLLM, or compatible API)
# For local Ollama: http://localhost:11434
# For Docker with host Ollama: http://host.docker.internal:11434
# For air-gap deployment: use internal IP
LLM_API_URL=http://host.docker.internal:11434

# Default LLM model to use
# For text: llama3, mistral, codellama, etc.
# For vision: llava, bakllava, etc.
LLM_MODEL=llama3

# =============================================================================
# Database Configuration (PostgreSQL with pgvector)
# =============================================================================

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://mcp:mcp@postgres:5432/knowledge

# Individual PostgreSQL settings (used by docker-compose)
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=knowledge

# =============================================================================
# Server Configuration
# =============================================================================

# MCP Server port (default: 8080)
MCP_PORT=8080

# =============================================================================
# Optional: External Service URLs (for air-gap environments)
# =============================================================================

# If you need to point to specific internal services, configure here
# EMBEDDING_SERVICE_URL=http://internal-embeddings:8000
# OCR_SERVICE_URL=http://internal-ocr:8000

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug logging
# DEBUG=true
